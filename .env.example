PORT=4178
HOST=0.0.0.0
DATA_DIR=./data

# Shopify
SHOPIFY_STORE_DOMAIN=pratosinteticoitalia.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Public base URL of the deployed app, used for webhook registration
WEBHOOK_BASE_URL=

# Automazione primo contatto richieste
# Modalita automazione primo contatto richieste: none | email | whatsapp
SALES_REQUEST_AUTOMATION_MODE=none

# Email follow-up automatico (provider: resend)
SALES_REQUEST_EMAIL_PROVIDER=resend
SALES_REQUEST_EMAIL_FROM=
SALES_REQUEST_EMAIL_REPLY_TO=
SALES_REQUEST_EMAIL_SUBJECT_PREFIX=Prato Sintetico Italia
SALES_REQUEST_EMAIL_TIMEOUT_MS=15000
RESEND_API_KEY=

# Default fallback (usato se non imposti valori specifici operatore)
WHATSAPP_AUTOMATION_ENABLED=true
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_COUNTRY_CODE=39
WHATSAPP_GRAPH_TIMEOUT_MS=15000

# Operatore Ivan (separato)
WHATSAPP_IVAN_ACCESS_TOKEN=
WHATSAPP_IVAN_PHONE_NUMBER_ID=

# Operatore Gabriele (separato)
WHATSAPP_GABRIELE_ACCESS_TOKEN=
WHATSAPP_GABRIELE_PHONE_NUMBER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# IMAP Shadow Worker (Fase 1 migrazione lead, Architettura B)
#
# Il worker resta DORMANT finché IMAP_SHADOW_ENABLED != "true".
# Quando attivo, polla la casella ogni IMAP_POLL_INTERVAL_MS millisecondi
# (default 5 min), legge le email nuove (UID delta) e le salva nella tabella
# incoming_leads_shadow per audit. NON le promuove ancora a sales_requests
# (questo arriva in Fase 3-4 della migrazione).
#
# Operazioni sulla casella: SOLO READ (mai delete/move/store con flag changes).
# Connessione TLS (porta 993 default).
# ─────────────────────────────────────────────────────────────────────────────
IMAP_SHADOW_ENABLED=false
# SiteGround: di solito mail.<dominio>. Verifica nel pannello SiteGround
# Site Tools → Email → Accounts → ⋮ → Mail Configuration → IMAP Server.
IMAP_HOST=mail.pratosinteticoitalia.it
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=contatti@pratosinteticoitalia.it
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=300000

# Fase 4 — Auto-promote: dopo ogni polling, riconcilia automaticamente i nuovi
# shadow leads (linkati a sales_requests esistenti, o creati come orfani).
# Default false: la riconciliazione resta manuale via UI Impostazioni → 📊 Diagnostica.
# Attivare a true solo quando IMAP shadow + riconciliazione manuale sono validati.
IMAP_AUTO_PROMOTE=false
